outputs/models/
outputs/reports/
outputs/figures/
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.bin
*.pb

# -----------------------------------------------------------------------------
# MLflow Artefacts
# -----------------------------------------------------------------------------
mlruns/
mlflow.db
mlartifacts/

# -----------------------------------------------------------------------------
# DVC Artefacts
# -----------------------------------------------------------------------------
.dvc/cache/
.dvc/tmp/
.dvc/plots/
*.dvc.lock

# Keep DVC config and pipeline definitions
!.dvc/.gitignore
!*.dvc

# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials/

# -----------------------------------------------------------------------------
