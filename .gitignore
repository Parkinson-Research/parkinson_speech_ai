# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.conda/
conda-env/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Dataset Files (use DVC instead)
# -----------------------------------------------------------------------------
data/raw/
data/processed/
*.wav
*.mp3
*.flac
*.ogg
*.m4a
*.aac
*.csv
*.tsv
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz

# -----------------------------------------------------------------------------
