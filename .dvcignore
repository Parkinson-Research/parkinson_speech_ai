# =============================================================================
# .dvcignore — Files and patterns DVC should not track
# Syntax is the same as .gitignore
# =============================================================================

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Log files
*.log
logs/

# IDE files
.vscode/
.idea/

# Virtual environments — never track these
.venv/
venv/
env/

# MLflow artefacts — tracked by MLflow, not DVC
mlruns/
mlartifacts/
mlflow.db

# Test fixtures and synthetic data — not real datasets
tests/fixtures/

# Outputs that are regenerated during training
# Track only the final best models, not intermediate checkpoints
outputs/figures/
outputs/reports/
