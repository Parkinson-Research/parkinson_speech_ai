# =============================================================================
# Parkinson Speech AI — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it is gitignored.
#
#   cp .env.example .env
#
# =============================================================================

# -----------------------------------------------------------------------------
# DagsHub Credentials
# Used by DVC for remote storage and by MLflow for experiment tracking.
# Get your token at: https://dagshub.com/user/settings/tokens
# -----------------------------------------------------------------------------
DAGSHUB_USERNAME=
DAGSHUB_TOKEN=

# -----------------------------------------------------------------------------
# MLflow Tracking
# DagsHub provides a hosted MLflow server for each repository.
# These values are auto-populated by the dagshub SDK when you call
# dagshub.init(), but can also be set manually.
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=https://dagshub.com/Parkinson-Research/parkinson_speech_ai.mlflow
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# -----------------------------------------------------------------------------
# Project Paths (optional overrides — defaults are relative to project root)
# Useful when data is stored on a separate drive or mounted volume.
# -----------------------------------------------------------------------------
# DATA_ROOT=/path/to/data
# OUTPUTS_ROOT=/path/to/outputs

# -----------------------------------------------------------------------------
# Training Environment
# -----------------------------------------------------------------------------
# CUDA_VISIBLE_DEVICES=0       # GPU index to use (leave blank for CPU)
# TOKENIZERS_PARALLELISM=false # Disable HuggingFace tokenizer warnings

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
